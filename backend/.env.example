APP_ENV=development
APP_NAME=Mohab AI Backend
API_V1_PREFIX=/api/v1
DEBUG=true
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mohab_ai
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=mohab-ai

OTEL_ENABLED=false
OTEL_SERVICE_NAME=mohab-ai-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
SERPER_API_KEY=
FAL_API_KEY=
GEMINI_API_KEY=
